{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "target": "esnext",
    "checkJs": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false
  },
  "exclude": ["node_modules"]
}
